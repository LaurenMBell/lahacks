generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  fullName           String
  passwordHash       String
  emailVerified      Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  settings           UserSettings?
  medicalProfile     MedicalProfile?
  articleSessions    ArticleSession[]
  followUpQuestions  FollowUpQuestion[]
  verificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MedicalProfile {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  ageRange                 String?
  weight                   String?
  sexAssignedAtBirth       String?
  gender                   String?
  familyMedicalHistory     String?
  substanceUse             Json?
  substanceUseOther        String?
  dietaryRestrictions      Json?
  dietaryRestrictionsOther String?
  conditions               String?
  medications              String?
  goals                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  lumaModeEnabled      Boolean  @default(true)
  autoAnalyzePages     Boolean  @default(false)
  showInPageHighlights Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ArticleSession {
  id                  String             @id @default(cuid())
  userId              String?
  url                 String
  normalizedUrl       String
  title               String
  sourceHost          String?
  pageType            String?
  rawText             String
  abstractText        String?
  authors             Json?
  journal             String?
  publishedAtLabel    String?
  pmid                String?
  doi                 String?
  headings            Json?
  extractionPayload   Json
  userProfileSnapshot Json?
  status              String             @default("pending")
  startedAt           DateTime           @default(now())
  lastViewedAt        DateTime           @default(now())
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  insights            ArticleInsight[]
  citations           ArticleCitation[]
  tags                ArticleTag[]
  followUpQuestions   FollowUpQuestion[]
  relatedArticles     RelatedArticle[]
  analysisJobs        AnalysisJob[]

  @@index([userId, lastViewedAt])
  @@index([normalizedUrl])
}

model ArticleInsight {
  id                     String         @id @default(cuid())
  articleSessionId       String
  summary                String
  userSpecificNotes      Json
  followUpSuggestions    Json
  relatedArticleKeywords Json
  warnings               Json
  relevanceScore         Float?
  modelName              String
  promptVersion          String
  rawModelResponse       String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  articleSession         ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)

  @@index([articleSessionId])
}

model ArticleCitation {
  id               String         @id @default(cuid())
  articleSessionId String
  label            String
  quote            String
  sourceSection    String?
  anchorText       String?
  explanation      String?
  orderIndex       Int            @default(0)
  createdAt        DateTime       @default(now())
  articleSession   ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)

  @@index([articleSessionId])
}

model ArticleTag {
  id               String         @id @default(cuid())
  articleSessionId String
  label            String
  value            String?
  category         String
  anchorText       String?
  orderIndex       Int            @default(0)
  createdAt        DateTime       @default(now())
  articleSession   ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)

  @@index([articleSessionId])
}

model FollowUpQuestion {
  id               String         @id @default(cuid())
  articleSessionId String
  userId           String?
  question         String
  answer           String?
  status           String         @default("pending")
  rawModelResponse String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  articleSession   ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleSessionId])
  @@index([userId])
}

model RelatedArticle {
  id               String         @id @default(cuid())
  articleSessionId String
  pmid             String?
  title            String
  journal          String?
  url              String?
  authors          Json?
  publishedAtLabel String?
  abstractSnippet  String?
  reasonMatched    String?
  sourceQuery      String?
  createdAt        DateTime       @default(now())
  articleSession   ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)

  @@index([articleSessionId])
}

model AnalysisJob {
  id               String         @id @default(cuid())
  articleSessionId String
  jobType          String
  status           String         @default("pending")
  attemptCount     Int            @default(0)
  lastError        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  articleSession   ArticleSession @relation(fields: [articleSessionId], references: [id], onDelete: Cascade)

  @@index([articleSessionId])
}
