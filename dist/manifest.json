{
  "manifest_version": 3,
  "name": "Luma",
  "version": "0.1.0",
  "description": "A women's health personalization side panel for contextual article insights.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Luma"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
